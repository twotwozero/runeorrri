RUNEORRRI_SITE_BASE_URL=https://runeorrri.pages.dev
# Backward-compatible fallback. Prefer RUNEORRRI_SITE_BASE_URL for new setups.
RUNNERI_SITE_BASE_URL=https://runeorrri.pages.dev
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-account@example.com
SMTP_PASSWORD=your-smtp-password
MAIL_FROM=your-account@example.com
MAIL_FROM_NAME=runeorrri
# Test/review recipients. Default local sends use this list.
MAIL_TO=reader@example.com
# Optional: skip recipients during subscriber sends, comma separated.
RUNEORRRI_SKIP_RECIPIENTS=
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_D1_DATABASE_ID=your-d1-database-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
# AI enrichment (Google Gemini - free tier: https://aistudio.google.com)
GEMINI_API_KEY=your-gemini-api-key
# Naver News API (https://developers.naver.com)
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret
