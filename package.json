{
  "name": "runeorrri",
  "private": true,
  "scripts": {
    "build": "npm --prefix web ci && npm --prefix web run build",
    "deploy": "npx wrangler pages deploy web/dist --project-name=runeorrri --branch=main",
    "send:test": "python3 scripts/send_issue_email.py --recipients test --issue-id latest",
    "verify:live": "python3 scripts/verify_live_issue.py",
    "publish": "python3 scripts/run_publish_workflow.py --confirm-subscriber-send",
    "dev": "npm --prefix web run dev",
    "preview": "npm --prefix web run preview",
    "d1:create": "wrangler d1 create runeorrri-subscribers",
    "d1:migrate": "wrangler d1 execute runeorrri-subscribers --file schema.sql"
  },
  "devDependencies": {
    "wrangler": "^3"
  }
}
